  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#555555",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#e0e0e0"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "scope": "keyword.other.unit",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.numeric",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "constant.language.boolean",
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.value"
      ],
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.definition.function"
      ],
      "settings": {
        "foreground": "#15ff00"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#ffcc00"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": [
        "support.constant.property-value",
        "support.constant.font-name",
        "support.constant.media-type",
        "support.constant.media"
      ],
      "settings": {
        "foreground": "#ffcc00"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#15ff00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#15ff00",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#555555",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.list",
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "scope": "markup.fenced_code.block",
      "settings": {
        "foreground": "#e0e0e0"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#15ff00"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "scope": "punctuation.definition.tag",
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#ff6600"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#e0e0e0"
      }
    },
    {
      "scope": "meta.preprocessor",
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#9012ff"
      }
    },
    {
      "scope": "meta.diff.index",
      "settings": {
        "foreground": "#15ff00"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "meta.separator",
      "settings": {
        "foreground": "#1e1e1e"
      }
    },
    {
      "scope": "support.constant.color.w3c-standard-color-name",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "support.variable",
      "settings": {
        "foreground": "#e0e0e0"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#15ff00"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#ff3333"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#9012ff"
      }
    }
  ]
